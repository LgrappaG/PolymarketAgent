# ============================================
# POLYMARKET AGENT - Environment Configuration
# ============================================
# This is a TEMPLATE. Copy to .env.local and fill in your values.
# NEVER commit .env.local to git (it's in .gitignore)
#
# ⚠️  DISCLAIMER: This is a TEST/DEMO project for educational purposes.
#     Do NOT use with real money or production credentials.
#     For paper trading simulation, most values can remain default.
# ============================================

# ========== ANTHROPIC (Claude) ==========
ANTHROPIC_API_KEY=sk-ant-...

# ========== BLOCKCHAIN & WALLET ==========
# Polygon Mainnet
PRIVATE_KEY=0x...
POLYGON_RPC_URL=https://polygon-rpc.com
WALLET_ADDRESS=0x...

# ========== POLYMARKET ==========
# Get from https://clob.polymarket.com dashboard
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_api_passphrase

# ========== DATA SOURCES ==========
# FiveThirtyEight (free, polls)
FIVETHIRTYEIGHT_API=https://projects.fivethirtyeight.com/

# NewsAPI (free tier: 3 req/min, paid increases quota)
NEWS_API_KEY=your_newsapi_key

# Twitter/X API v2 (Essential tier: ~$100/month)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ESPN (free, scraping)
ESPN_API_ENDPOINT=https://site.api.espn.com

# ========== OPTIONAL: BOOKMAKER ODDS ==========
# Pinnacle (for arbitrage detection)
PINNACLE_API_KEY=your_pinnacle_key

# ========== TRADING PARAMETERS ==========
# Start conservative
INITIAL_BALANCE=500  # USDC
MAX_POSITION_SIZE=0.02  # 2% of balance per trade
MIN_CONFIDENCE_AUTO=0.75  # Auto-trade threshold
MIN_CONFIDENCE_APPROVAL=0.60  # Needs human approval
MAX_LOSS_PERCENT=0.05  # Stop-loss at 5%

# ========== EXECUTION MODE ==========
# Options: PAPER (simulation), APPROVAL (human review), AUTO (fully automatic)
EXECUTION_MODE=APPROVAL

# ========== LOGGING ==========
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/agent.log

# ========== OPTIONAL: DATA COLLECTION ==========
# Collect market data every N seconds
POLL_INTERVAL=300  # 5 minutes for stable markets
CRYPTO_UPDATE_INTERVAL=60  # 1 minute for crypto

# ========== OPTIONAL: ALERT SETTINGS ==========
# Slack/Discord webhook for trade alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
